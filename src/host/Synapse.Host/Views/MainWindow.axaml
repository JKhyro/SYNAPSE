<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Synapse.Host.ViewModels"
        x:Class="Synapse.Host.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1240"
        Height="780"
        MinWidth="960"
        MinHeight="640"
        Title="SYNAPSE">
  <Grid Background="#0A1020" RowDefinitions="Auto,*" ColumnDefinitions="340,*" Margin="24">
    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#16203A"
            BorderBrush="#31436F"
            BorderThickness="1"
            CornerRadius="18"
            Padding="20"
            Margin="0,0,0,18">
      <StackPanel Spacing="8">
        <TextBlock Text="SYNAPSE"
                   FontSize="34"
                   FontWeight="SemiBold"
                   Foreground="#F2F5FF" />
        <TextBlock Text="{Binding BoundarySummary}"
                   TextWrapping="Wrap"
                   Foreground="#C0CAE8" />
        <TextBlock Text="{Binding HostSummary}"
                   TextWrapping="Wrap"
                   Foreground="#92A3D5" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#121A30"
            BorderBrush="#31436F"
            BorderThickness="1"
            CornerRadius="18"
            Padding="16"
            Margin="0,0,18,0">
      <StackPanel Spacing="12">
        <TextBlock Text="Sections"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#F2F5FF" />
        <TextBlock Text="{Binding NativeStatus}"
                   TextWrapping="Wrap"
                   Foreground="#A8B7E6" />
        <ListBox ItemsSource="{Binding Sections}"
                 SelectedItem="{Binding SelectedSection}"
                 BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SectionDescriptorViewModel">
              <Border Background="#1A2544"
                      BorderBrush="#2E4271"
                      BorderThickness="1"
                      CornerRadius="14"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Title}"
                             FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="#F2F5FF" />
                  <TextBlock Text="{Binding Surface}"
                             Foreground="#C0CAE8"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding EntrySymbol}"
                             Foreground="#84D7C8" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="1"
            Background="#121A30"
            BorderBrush="#31436F"
            BorderThickness="1"
            CornerRadius="18"
            Padding="20">
      <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        <TextBlock Text="Selected Section"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#F2F5FF" />

        <StackPanel Grid.Row="1"
                    Spacing="8"
                    Margin="0,16,0,0">
          <TextBlock Text="{Binding SelectedSection.Title, FallbackValue=No section selected}"
                     FontSize="26"
                     FontWeight="SemiBold"
                     Foreground="#F2F5FF" />
          <TextBlock Text="{Binding SelectedSection.Surface}"
                     TextWrapping="Wrap"
                     Foreground="#C0CAE8" />
          <TextBlock Text="{Binding SelectedSection.LaunchOwner, StringFormat=Launch owner: {0}}"
                     Foreground="#92A3D5" />
          <TextBlock Text="{Binding SelectedSection.PresentationMode, StringFormat=Presentation: {0}}"
                     Foreground="#92A3D5" />
          <TextBlock Text="{Binding SelectedSection.EntrySymbol, StringFormat=Native symbol: {0}}"
                     Foreground="#84D7C8" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="#0D162A"
                BorderBrush="#2E4271"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16"
                Margin="0,20,0,0">
          <TextBlock Text="This host only owns shell chrome and interop glue. Runtime section ownership remains on the Native C side."
                     TextWrapping="Wrap"
                     Foreground="#DDE4FF" />
        </Border>

        <Border Grid.Row="3"
                Background="#182646"
                CornerRadius="18"
                Padding="18"
                Margin="0,20,0,20">
          <TextBlock Text="{Binding LastAction}"
                     TextWrapping="Wrap"
                     Foreground="#F2F5FF" />
        </Border>

        <Button Grid.Row="4"
                HorizontalAlignment="Left"
                Padding="20,10"
                Background="#84D7C8"
                Foreground="#06121D"
                FontWeight="SemiBold"
                IsEnabled="{Binding CanLaunchSelectedSection}"
                Click="OpenSelectedSection">
          Invoke Native Stub
        </Button>
      </Grid>
    </Border>
  </Grid>
</Window>
